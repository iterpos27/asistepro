{
  "name": "asistepro",
  "version": "1.0.0",
  "private": true,
  "description": "ASISTEPRO SaaS multi-tenant attendance platform",
  "scripts": {
    "dev": "node backend/src/server.js",
    "start": "node backend/src/database/migrate.js && node backend/src/server.js",
    "check": "node --check backend/src/server.js",
    "test": "node --test \"backend/tests/*.test.js\"",
    "migrate": "node backend/src/database/migrate.js",
    "check-expirations": "node backend/src/scripts/check-expirations.js",
    "backup:verify": "node backend/src/scripts/verify-backup.js"
  },
  "engines": {
    "node": ">=20.19"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  }
}
